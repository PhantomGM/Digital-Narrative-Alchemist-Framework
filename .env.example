# ──────────────────────────────────────────────────────────────────────
# DNA Framework — Multi-Provider Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the keys for your active providers.
# You do NOT need all providers — the ModelRouter silently skips any
# provider whose key is missing. At minimum, configure ONE provider.
# ──────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────
# Required for: GPT-5 nano (Orchestrator, State Critic),
#               GPT-4o mini (Safety Governor), GPT-5.4 mini (Auditor Patch)
OPENAI_API_KEY=

# ── Anthropic ────────────────────────────────────────────────────────
# Required for: Claude Opus 4.6 (Narrative Weaver, DNA Decoder, History Consensus),
#               Claude Sonnet 4.6 (Auditor Patch), Claude Haiku 4.5 (Auditor, Lore Extractor)
ANTHROPIC_API_KEY=

# ── Google (Gemini) ──────────────────────────────────────────────────
# Required for: Gemini 2.5 Flash-Lite (Orchestrator, Safety Governor),
#               Gemini 2.5 Flash (Chronicler, Auditor, Lore Extractor),
#               Gemini 2.5 Pro (Narrative Weaver, History Consensus)
GOOGLE_API_KEY=

# ── Groq ─────────────────────────────────────────────────────────────
# Required for: Llama 4 Scout (Orchestrator, State Critic),
#               Llama 4 Maverick (Narrative Weaver, DNA Decoder)
GROQ_API_KEY=

# ── DeepSeek ─────────────────────────────────────────────────────────
# Required for: DeepSeek V3.2 (Auditor, Chronicler, Lore Extractor),
#               DeepSeek R1 (DNA Decoder, History Consensus)
DEEPSEEK_API_KEY=

# ── Mistral ──────────────────────────────────────────────────────────
# Required for: Mistral Small 3.1 (Safety Governor, State Critic),
#               Mistral Medium 3.1 (Auditor Patch, Chronicler)
MISTRAL_API_KEY=

# ── Ollama (Local) ───────────────────────────────────────────────────
# For local model inference. No API key needed for most setups.
OLLAMA_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
